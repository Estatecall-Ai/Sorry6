    <script>
        const noBtn = document.getElementById('no-btn');
        const yesBtn = document.getElementById('yes-btn');
        const apologyCard = document.getElementById('apology-card');
        const successScreen = document.getElementById('success-screen');

        const funnyMessages = [
            "Nahi, Katti! 😤",
            "Aise thodi hota hai! 🏃‍♂️",
            "Pakad ke dikha! 😜",
            "Maan ja na chudail! 🧙‍♀️",
            "Ziddi kahiki! 😒",
            "Bas kar de ab! 😂",
            "You can't catch me! 💨",
            "Chaitanya is the best! 😇"
        ];
        
        let messageIndex = 0;

        function dodgeButton() {
            messageIndex = (messageIndex + 1) % funnyMessages.length;
            noBtn.innerText = funnyMessages[messageIndex];

            const maxMoveX = 100; 
            const maxMoveY = 80;  
            
            const randomX = (Math.random() * maxMoveX * 2) - maxMoveX;
            const randomY = (Math.random() * maxMoveY * 2) - maxMoveY;
            const randomRotate = (Math.random() * 20) - 10;

            noBtn.style.transform = `translate(${randomX}px, ${randomY}px) rotate(${randomRotate}deg) scale(0.9)`;
        }

        noBtn.addEventListener('mouseover', dodgeButton);
        
        noBtn.addEventListener('touchstart', (e) => {
            e.preventDefault(); 
            dodgeButton();
        });

        noBtn.addEventListener('click', (e) => {
            e.preventDefault();
            dodgeButton();
        });

        yesBtn.addEventListener('click', () => {
            apologyCard.classList.add('hidden');
            successScreen.classList.remove('hidden');
            window.scrollTo(0, 0);
            
            const duration = 6000;
            const end = Date.now() + duration;

            (function frame() {
                confetti({
                    particleCount: 10,
                    angle: 60,
                    spread: 80,
                    origin: { x: 0 },
                    colors: ['#ff0000', '#ffc0cb', '#ffff00', '#00ff00', '#0000ff', '#ff00ff']
                });
                confetti({
                    particleCount: 10,
                    angle: 120,
                    spread: 80,
                    origin: { x: 1 },
                    colors: ['#ff0000', '#ffc0cb', '#ffff00', '#00ff00', '#0000ff', '#ff00ff']
                });

                if (Date.now() < end) {
                    requestAnimationFrame(frame);
                }
            }());
        });
    </script>
</body>
</html>


