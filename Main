    <!-- Main Apology Card -->
    <div id="apology-card" class="bg-white/80 backdrop-blur-xl p-6 md:p-10 rounded-[2rem] shadow-2xl max-w-lg w-full text-center border-4 border-dashed border-pink-400 relative z-10 my-8">
        
        <div class="text-7xl mb-2 floating fade-in-up">🐒🫣</div>
        
        <h1 class="text-3xl sm:text-4xl font-black text-red-500 mb-6 fade-in-up delay-1 bounce-fast tracking-wide">
